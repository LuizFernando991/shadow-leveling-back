APP_ENV=development
APP_PORT=8080
APP_NAME=gym-api

LOG_LEVEL=debug

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gym_db
DB_SSLMODE=disable

AUTH_JWT_SECRET=change-me-in-production
AUTH_TOKEN_TTL=1000h

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
# Image storage (Firebase Storage / GCS bucket).
# Leave STORAGE_BUCKET empty to disable uploads (noop) in local dev.
STORAGE_BUCKET=
# Credentials — set EITHER the three fields below (preferred; pass as secrets in prod)
# OR a path to the JSON file (dev convenience). Fields win when both are set.
# In STORAGE_PRIVATE_KEY keep the "\n" escapes from the JSON as-is (quote the value).
STORAGE_PROJECT_ID=
STORAGE_CLIENT_EMAIL=
STORAGE_PRIVATE_KEY=
STORAGE_SA_JSON_PATH=
